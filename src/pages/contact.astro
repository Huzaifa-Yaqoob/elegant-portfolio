---
import PageLayout from "@/layouts/page-layout.astro"
import ContactPageContent from "@/components/contact/contact-page-content.astro"
import ContactSocial from "@/components/contact/contact-social.astro"
import FaqSection from "@/components/faq/faq-section.astro"
import { getCollection } from "astro:content"

const contactIndex = await getCollection("contactIndex")
const indexData = contactIndex[0]?.data

if (!indexData) {
  throw new Error("Contact index content not found")
}

const siteUrl = Astro.site?.origin ?? "https://huzaifa.dev"
---

<PageLayout
  title={indexData.title}
  description={indexData.description}
  videoLink={indexData.videoLink}
  mainImage={indexData.mainImage}
  showCTA={false}
  pageTitle="Hire a Full-Stack Developer | React & Node.js | Huzaifa"
  pageDescription="Ready to build your next project? Contact a full-stack developer specializing in React and Node.js. Get a free consultation and timeline estimate within 24h."
  canonicalUrl={`${siteUrl}/contact`}
>
  <ContactPageContent />
  <FaqSection showDivider={false} />
  <ContactSocial />
</PageLayout>

---
import PageLayout from "@/layouts/page-layout.astro"
import PortfolioShowcase from "@/components/portfolio/portfolio-showcase.astro"
import { getCollection } from "astro:content"

const portfolioIndex = await getCollection("portfolioIndex")
const indexData = portfolioIndex[0]?.data

if (!indexData) {
  throw new Error("Portfolio index content not found")
}
---

<PageLayout
  title={indexData.title}
  description={indexData.description}
  videoLink={indexData.videoLink}
  mainImage={indexData.mainImage}
  pageTitle="Web Development Portfolio | React & TypeScript Projects | Huzaifa.Dev"
  pageDescription="Explore a portfolio of React, TypeScript, and full-stack web development projects. From SaaS platforms to compliance systems — built by a full-stack web developer in Pakistan."
  canonicalUrl="https://huzaifa.dev/my-work"
>
  <PortfolioShowcase />
</PageLayout>

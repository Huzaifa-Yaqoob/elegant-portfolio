---
import { getCollection, render } from "astro:content"
import Layout from "@/layouts/main.astro"
import ProjectHeader from "@/components/portfolio/project-header.astro"
import ProjectNavigation from "@/components/portfolio/project-navigation.astro"
import ContactCTA from "@/components/contact-cta.astro"

export async function getStaticPaths() {
  const allEntries = await getCollection("portfolio")
  return allEntries.map((entry) => ({
    params: { slug: entry.data.slug },
  }))
}

const { slug } = Astro.params
const entries = await getCollection("portfolio")
const entry = entries.find((e) => e.data.slug === slug)
const { data } = entry!
const { Content } = await render(entry!)

const siteData = await getCollection("site")
const site = siteData[0]?.data
const siteUrl = site?.site_url ?? "https://huzaifa.dev"
const canonical = `${siteUrl}/my-work/${data.slug}`

const sorted = entries.sort((a, b) => a.data.order - b.data.order)
const currentIndex = sorted.findIndex((e) => e.data.slug === data.slug)
const prevProject =
  currentIndex > 0
    ? {
        slug: sorted[currentIndex - 1].data.slug,
        title: sorted[currentIndex - 1].data.title,
      }
    : undefined
const nextProject =
  currentIndex < sorted.length - 1
    ? {
        slug: sorted[currentIndex + 1].data.slug,
        title: sorted[currentIndex + 1].data.title,
      }
    : undefined

const pageTitle = `${data.title} — Full-Stack Web Development Project | Huzaifa.Dev`
const pageKeywords = data.tags?.length
  ? data.tags.join(", ")
  : "full-stack development, web application, SaaS platform"
---

<Layout
  pageTitle={pageTitle}
  pageDescription={data.description}
  pageImage={data.mainImage}
  canonicalUrl={canonical}
  ogType="article"
  pageKeywords={pageKeywords}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: data.title,
      description: data.description,
      url: data.url || canonical,
      applicationCategory: "BusinessApplication",
      operatingSystem: "Web",
      author: {
        "@type": "Person",
        name: "Huzaifa",
        url: siteUrl,
      },
      offers: data.url
        ? {
            "@type": "Offer",
            url: data.url,
          }
        : undefined,
    })}
  />

  <article>
    <ProjectHeader
      title={data.title}
      description={data.description}
      url={data.url}
      tools={data.tools}
      role={data.role}
      timeline={data.timeline}
      company={data.company}
      companyUrl={data.companyUrl}
      images={data.images}
    />

    <div id="project-content-wrapper" class="relative mx-auto max-w-5xl">
      <!-- Decorative side titles on large screens -->
      <div class="absolute inset-y-0 -left-48 hidden items-center xl:flex">
        <span
          id="side-title-left"
          class="font-heading text-[clamp(5rem,8vw,10rem)] leading-none font-black tracking-tighter text-surface-variant/40 select-none"
          style="writing-mode: vertical-lr"
        >
          {data.title}
        </span>
      </div>
      <div class="absolute inset-y-0 -right-48 hidden items-center xl:flex">
        <span
          id="side-title-right"
          class="font-heading text-[clamp(5rem,8vw,10rem)] leading-none font-black tracking-tighter text-surface-variant/40 select-none"
          style="writing-mode: vertical-rl"
        >
          {data.title}
        </span>
      </div>
      <Content />
    </div>

    <ProjectNavigation prevProject={prevProject} nextProject={nextProject} />
  </article>

  <ContactCTA />
</Layout>

<script>
  import { gsap, SplitText } from "@/lib/gsap"

  window.addEventListener("load", () => {
    gsap.matchMedia()

    // Section scroll-in animations
    const sections = document.querySelectorAll(".project-section")
    sections.forEach((section) => {
      const heading = section.querySelector(".section-heading")
      const content = section.querySelector(".section-content")

      gsap.fromTo(
        section,
        { opacity: 0, y: 80 },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: section,
            start: "top 85%",
            toggleActions: "play none none reverse",
          },
        }
      )

      if (heading) {
        gsap.fromTo(
          heading,
          { opacity: 0, x: -30 },
          {
            opacity: 1,
            x: 0,
            duration: 0.6,
            ease: "power2.out",
            scrollTrigger: {
              trigger: heading,
              start: "top 85%",
              toggleActions: "play none none reverse",
            },
          }
        )
      }

      if (content) {
        gsap.fromTo(
          content,
          { opacity: 0, y: 40 },
          {
            opacity: 1,
            y: 0,
            duration: 0.6,
            delay: 0.2,
            ease: "power2.out",
            scrollTrigger: {
              trigger: content,
              start: "top 85%",
              toggleActions: "play none none reverse",
            },
          }
        )
      }
    })

    // SplitText writing effect for side titles
    const wrapper = document.querySelector("#project-content-wrapper")
    const leftEl = document.querySelector("#side-title-left")
    const rightEl = document.querySelector("#side-title-right")

    if (wrapper && leftEl && rightEl) {
      const leftSplit = SplitText.create(leftEl, {
        type: "chars",
        tag: "span",
      })
      const rightSplit = SplitText.create(rightEl, {
        type: "chars",
        tag: "span",
      })

      gsap.set(leftSplit.chars, { opacity: 0, y: 30 })
      gsap.set(rightSplit.chars, { opacity: 0, y: 30 })

      const scrollTl = gsap.timeline({
        scrollTrigger: {
          trigger: wrapper,
          start: "top bottom",
          end: "bottom top",
          scrub: 1,
        },
      })

      scrollTl
        .to(leftSplit.chars, {
          opacity: 1,
          y: 0,
          duration: 0.5,
          stagger: { each: 0.04, from: "start" },
          ease: "power2.out",
        })
        .to(
          rightSplit.chars,
          {
            opacity: 1,
            y: 0,
            duration: 0.5,
            stagger: { each: 0.04, from: "start" },
            ease: "power2.out",
          },
          0
        )
    }
  })
</script>

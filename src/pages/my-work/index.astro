---
import PageLayout from "@/layouts/page-layout.astro"
import PortfolioShowcase from "@/components/portfolio/portfolio-showcase.astro"
import { getCollection } from "astro:content"

const portfolioIndex = await getCollection("portfolioIndex")
const indexData = portfolioIndex[0]?.data

if (!indexData) {
  throw new Error("Portfolio index content not found")
}

const siteUrl = Astro.site?.origin ?? "https://huzaifa.dev"
---

<PageLayout
  title={indexData.title}
  description={indexData.description}
  videoLink={indexData.videoLink}
  mainImage={indexData.mainImage}
  pageTitle={indexData.seo_title}
  pageDescription={indexData.seo_description}
  pageKeywords={indexData.seo_keywords}
  canonicalUrl={`${siteUrl}/my-work`}
>
  <PortfolioShowcase />
</PageLayout>

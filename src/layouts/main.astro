---
import "@/styles/global.css"
import Navbar from "@/components/navbar/navbar.astro"
import Footer from "@/components/footer/footer.astro"
import SmoothScroller from "./smooth-scroller.astro"
import CustomScrollbar from "@/components/animation/custom-scrollbar.astro"
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Huzaifa.Dev Portfolio</title>
  </head>
  <body class="flex min-h-svh flex-col">
    <Navbar />
    <CustomScrollbar />
    <SmoothScroller>
      <main class="grow">
        <slot />
      </main>
      <Footer />
    </SmoothScroller>
  </body>
</html>

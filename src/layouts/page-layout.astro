---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/page-header.astro"
import ContactCTA from "@/components/contact-cta.astro"

interface Props {
  title: string
  description: string
  videoLink: string
  mainImage: string
  showCTA?: boolean
  pageTitle?: string
  pageDescription?: string
  canonicalUrl?: string
}

const {
  title,
  description,
  videoLink,
  mainImage,
  showCTA = true,
  pageTitle,
  pageDescription,
  canonicalUrl,
} = Astro.props
---

<Layout
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  pageImage={mainImage}
  canonicalUrl={canonicalUrl}
>
  <PageHeader
    title={title}
    description={description}
    videoLink={videoLink}
    mainImage={mainImage}
  />

  <slot />

  {showCTA && <ContactCTA />}
</Layout>

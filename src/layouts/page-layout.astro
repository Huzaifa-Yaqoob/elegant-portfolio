---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/page-header.astro"
import ContactCTA from "@/components/contact-cta.astro"

interface Props {
  title: string
  description: string
  videoLink: string
  mainImage: string
  showCTA?: boolean
}

const { title, description, videoLink, mainImage, showCTA = true } = Astro.props
---

<Layout>
  <PageHeader
    title={title}
    description={description}
    videoLink={videoLink}
    mainImage={mainImage}
  />

  <slot />

  {showCTA && <ContactCTA />}
</Layout>

---
import Divider from "@/components/divider.astro"

interface Props {
  title: string
  description?: string
  divider_text?: string
  badge?: string
  showDivider?: boolean
}

const {
  title,
  description,
  divider_text,
  badge,
  showDivider = true,
} = Astro.props
---

<section class="px-6 py-10 lg:px-16">
  <div class="m flex flex-col justify-between md:flex-row lg:items-end">
    <h2 class="h1-style mb-6 text-on-surface uppercase">
      {title.split(" ")[0]}<br />{title.split(" ").slice(1).join(" ")}
    </h2>
    <div class="flex flex-col justify-end text-right md:col-span-4">
      <p
        class="mb-4 font-mono-code text-mono-code tracking-widest text-outline uppercase"
      >
        [ {badge} ]
      </p>
      <p
        class="ml-auto max-w-sm font-body-lg text-body-lg text-on-surface-variant"
      >
        {description}
      </p>
    </div>
  </div>
  {divider_text && <Divider text={divider_text} />}

  <slot />

  {showDivider && <div class="mx-auto mt-8 h-1 max-w-80 bg-foreground" />}
</section>

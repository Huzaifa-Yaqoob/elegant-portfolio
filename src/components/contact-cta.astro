---
import SparkleLayout from "@/layouts/sparkle-layout.astro"
---

<SparkleLayout id="cta" class="border-y border-surface-variant px-8 py-32 lg:px-16">
  <div class="flex w-full items-center justify-center">
    <div id="magnetic-cta-zone" class="relative">
      <a
        href="/contact"
        id="magnetic-cta"
        data-lag="0.5"
        class="group relative z-10 mx-auto flex aspect-square w-70 items-center justify-center border border-on-surface bg-background transition-colors duration-500 hover:bg-on-surface hover:text-background md:w-[360px] lg:w-[420px]"
      >
        <span
          id="magnetic-cta-text"
          class="font-heading text-4xl font-black tracking-tighter uppercase transition-transform duration-500 group-hover:scale-110 md:text-5xl lg:text-6xl"
        >
          Let's<br />Talk
        </span>
      </a>
    </div>
  </div>
</SparkleLayout>

<script>
  import { gsap } from "@/lib/gsap"

  const setCursorState = (state: string) => {
    window.dispatchEvent(
      new CustomEvent("cursor-state-change", { detail: { state } })
    )
  }

  const zone = document.getElementById("magnetic-cta-zone")
  if (!zone) throw new Error("Magnetic CTA zone not found")

  const btn = document.getElementById("magnetic-cta")
  if (!btn) throw new Error("Magnetic CTA not found")

  const textEl = document.getElementById("magnetic-cta-text")
  if (!textEl) throw new Error("Magnetic CTA text not found")

  const magneticPadding = 80
  const maxDisplacement = 150
  const duration = 0.2
  let isHovering = false
  let rafId: number | null = null
  let latestEvent: { clientX: number; clientY: number } | null = null
  let btnRect: DOMRect

  zone.style.padding = `${magneticPadding}px`

  const handleMouseEnter = () => {
    btnRect = btn.getBoundingClientRect()
  }

  const handleMouseMove = (e: MouseEvent) => {
    latestEvent = { clientX: e.clientX, clientY: e.clientY }

    if (rafId === null) {
      rafId = requestAnimationFrame(() => {
        rafId = null
        if (!latestEvent || !btnRect) return

        const centerX = btnRect.left + btnRect.width / 2
        const centerY = btnRect.top + btnRect.height / 2

        const deltaX = latestEvent.clientX - centerX
        const deltaY = latestEvent.clientY - centerY
        const dist = Math.hypot(deltaX, deltaY)

        const maxDist =
          Math.max(btnRect.width, btnRect.height) / 2 + magneticPadding
        const normalizedDist = dist / maxDist
        const attenuation = Math.pow(1 - normalizedDist, 1.5)
        const moveX = deltaX * attenuation * (maxDisplacement / maxDist)
        const moveY = deltaY * attenuation * (maxDisplacement / maxDist)

        if (!isHovering) {
          isHovering = true
          setCursorState("hidden")
        }

        gsap.to(btn, {
          x: moveX,
          y: moveY,
          duration,
          ease: "power3.out",
          overwrite: true,
        })
      })
    }
  }

  const handleMouseLeave = () => {
    isHovering = false
    latestEvent = null
    setCursorState("default")

    if (rafId !== null) {
      cancelAnimationFrame(rafId)
      rafId = null
    }

    gsap.to(btn, {
      x: 0,
      y: 0,
      duration: 0.5,
      ease: "elastic.out(1, 0.5)",
      overwrite: true,
    })
  }

  zone.addEventListener("mouseenter", handleMouseEnter)
  zone.addEventListener("mousemove", handleMouseMove)
  zone.addEventListener("mouseleave", handleMouseLeave)
</script>

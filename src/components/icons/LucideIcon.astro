---
import { AstroError } from 'astro/errors';
import * as LucideIcons from 'lucide-react';

interface Props {
  name: string;
  size?: string;
  class?: string;
}

const { name, size = '24', class: className } = Astro.props;

const iconComponentName = name
  .split('-')
  .filter(Boolean)
  .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
  .join('');

const IconComponent = (LucideIcons as Record<string, unknown>)[iconComponentName];

if (!IconComponent) {
  console.error(`Could not find Lucide Icon: ${name} (${iconComponentName})`);
  throw new AstroError(
    `Lucide Icon "${name}" not found.`,
    `Please ensure the icon name is valid for lucide-react exports.`
  );
}
---

<IconComponent size={Number(size)} className={className} />

---
interface Props {
  name: string
  email: string
  phone: string
  address: string
  addressLink: string
  responseTime: string
}

const { name, email, phone, address, addressLink, responseTime } = Astro.props
---

<div class="space-y-6">
  <div
    class="rounded-none border border-outline-variant bg-surface-container-low p-6 md:p-8"
  >
    <h3 class="mb-4 h3-style text-on-surface uppercase">Contact Details</h3>
    <div class="space-y-4">
      <div>
        <p class="label-caps-style mb-1 text-on-surface-variant">Name</p>
        <p class="body-lg-style text-on-surface">{name}</p>
      </div>
      <div>
        <p class="label-caps-style mb-1 text-on-surface-variant">Email</p>
        <a
          href={`mailto:${email}`}
          class="body-lg-style text-on-surface transition-colors hover:text-primary"
          >{email}</a
        >
      </div>
      <div>
        <p class="label-caps-style mb-1 text-on-surface-variant">Phone</p>
        <a
          href={`tel:${phone}`}
          class="body-lg-style text-on-surface transition-colors hover:text-primary"
          >{phone}</a
        >
      </div>
      <div>
        <p class="label-caps-style mb-1 text-on-surface-variant">Address</p>
        <a
          href={addressLink}
          target="_blank"
          rel="noopener noreferrer"
          class="body-lg-style text-on-surface transition-colors hover:text-primary"
          >{address}</a
        >
      </div>
    </div>
  </div>

  <div
    class="rounded-none border border-outline-variant bg-surface-container-low p-6 md:p-8"
  >
    <h3 class="mb-4 h3-style text-on-surface uppercase">Location</h3>
    <a
      href={addressLink}
      target="_blank"
      rel="noopener noreferrer"
      class="block h-56 overflow-hidden rounded-none border border-outline-variant bg-surface"
    >
      <iframe
        title="Map location"
        src={addressLink}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="h-full w-full border-0"></iframe>
    </a>
    <p class="mt-4 body-sm-style text-on-surface-variant">{responseTime}</p>
  </div>
</div>

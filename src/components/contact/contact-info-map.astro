---
import LucideIcon from "@/components/icons/LucideIcon"

interface Props {
  email: string
  phone: string
  address: string
  addressLink: string
  responseTime: string
}

const { email, phone, address, addressLink, responseTime } = Astro.props
---

<div class="space-y-6">
  <div
    class="rounded-none border border-outline-variant bg-surface-container-low p-6 md:p-8"
  >
    <h3 class="mb-4 h3-style text-on-surface uppercase">Contact Details</h3>
    <div class="space-y-4">
      <div>
        <p class="label-caps-style mb-1 text-on-surface-variant">Email</p>
        <a
          href={`mailto:${email}`}
          class="group/action flex items-center gap-3 border border-transparent p-2 transition-colors hover:border-on-surface"
        >
          <LucideIcon
            name="Mail"
            size={18}
            class="shrink-0 text-on-surface-variant"
          />
          <span class="flex-1 body-lg-style text-on-surface">{email}</span>
          <span
            class="inline-flex size-10 shrink-0 items-center justify-center border border-on-surface text-on-surface transition-colors duration-300 group-hover/action:bg-on-surface group-hover/action:text-background"
          >
            <LucideIcon
              name="ArrowUpRight"
              size={18}
              class="transition-transform duration-300 group-hover/action:translate-x-0.5 group-hover/action:-translate-y-0.5"
            />
          </span>
        </a>
      </div>
      <div>
        <p class="label-caps-style mb-1 text-on-surface-variant">Phone</p>
        <a
          href={`tel:${phone}`}
          class="group/action flex items-center gap-3 border border-transparent p-2 transition-colors hover:border-on-surface"
        >
          <LucideIcon
            name="Phone"
            size={18}
            class="shrink-0 text-on-surface-variant"
          />
          <span class="flex-1 body-lg-style text-on-surface">{phone}</span>
          <span
            class="inline-flex size-10 shrink-0 items-center justify-center border border-on-surface text-on-surface transition-colors duration-300 group-hover/action:bg-on-surface group-hover/action:text-background"
          >
            <LucideIcon
              name="ArrowUpRight"
              size={18}
              class="transition-transform duration-300 group-hover/action:translate-x-0.5 group-hover/action:-translate-y-0.5"
            />
          </span>
        </a>
      </div>
      <div>
        <p class="label-caps-style mb-1 text-on-surface-variant">Address</p>
        <a
          href={addressLink}
          target="_blank"
          rel="noopener noreferrer"
          class="group/action flex items-center gap-3 border border-transparent p-2 transition-colors hover:border-on-surface"
        >
          <LucideIcon
            name="MapPin"
            size={18}
            class="shrink-0 text-on-surface-variant"
          />
          <span class="flex-1 body-lg-style text-on-surface">{address}</span>
          <span
            class="inline-flex size-10 shrink-0 items-center justify-center border border-on-surface text-on-surface transition-colors duration-300 group-hover/action:bg-on-surface group-hover/action:text-background"
          >
            <LucideIcon
              name="ArrowUpRight"
              size={18}
              class="transition-transform duration-300 group-hover/action:translate-x-0.5 group-hover/action:-translate-y-0.5"
            />
          </span>
        </a>
      </div>
    </div>
  </div>

  <div
    class="rounded-none border border-outline-variant bg-surface-container-low p-6 md:p-8"
  >
    <h3 class="mb-4 h3-style text-on-surface uppercase">Location</h3>
    <a
      href={addressLink}
      target="_blank"
      rel="noopener noreferrer"
      class="block h-56 overflow-hidden rounded-none border border-outline-variant bg-surface"
    >
      <iframe
        title="Map location"
        src={addressLink}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="h-full w-full border-0 brightness-90 contrast-125 grayscale"
      ></iframe>
    </a>
    <p class="mt-4 body-sm-style text-on-surface-variant">{responseTime}</p>
  </div>
</div>

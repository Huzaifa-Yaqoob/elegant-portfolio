---
import { getEntry } from "astro:content"
import SparkleLayout from "@/layouts/sparkle-layout.astro"
import GithubIcon from "@/components/icons/tech_stack/github.astro"
import XIcon from "../icons/social/x.astro"
import InstagramIcon from "../icons/social/instagram.astro"
import FacebookIcon from "../icons/social/facebook.astro"
import DiscordIcon from "../icons/social/discord.astro"
import WhatsAppIcon from "../icons/social/whatsapp.astro"
import LinkedInIcon from "../icons/social/linkedin.astro"

const siteEntry = await getEntry("site", "site")
if (!siteEntry) return ""

const { social } = siteEntry.data

interface SocialLink {
  label: string
  url: string
  icon: typeof GithubIcon
  filter?: boolean
}

const links: SocialLink[] = [
  { label: "GitHub", url: social.github, icon: GithubIcon },
  { label: "X [TWITTER]", url: social.x, icon: XIcon },
  { label: "Instagram", url: social.instagram, icon: InstagramIcon },
  { label: "Facebook", url: social.facebook, icon: FacebookIcon },
  { label: "Discord", url: social.discord, icon: DiscordIcon },
  { label: "WhatsApp", url: social.whatsapp, icon: WhatsAppIcon },
  { label: "LinkedIn", url: social.linkedin, icon: LinkedInIcon, filter: true },
]
---

<SparkleLayout
  id="social"
  class="border-y border-surface-variant px-8 py-24 md:px-16"
>
  <div class="mx-auto max-w-7xl">
    <h2
      class="mb-4 font-heading text-4xl font-black tracking-tighter text-on-surface uppercase"
    >
      Find Me Elsewhere
    </h2>
    <p class="mb-16 max-w-lg text-lg text-on-surface-variant">
      Beyond the inbox, catch me across the digital landscape.
    </p>
    <div
      class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-[repeat(auto-fill,minmax(160px,1fr))]"
    >
      {
        links.map(({ label, url, icon: Icon, filter }) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center justify-center gap-3 border border-surface-variant bg-background p-8 transition-colors duration-300 hover:bg-on-surface"
          >
            <Icon
              class={`h-7 w-7 text-on-surface transition-all duration-300 ${filter ? "brightness-150 saturate-0 group-hover:text-background group-hover:brightness-100 group-hover:saturate-100" : "group-hover:text-background"}`}
            />
            <span class="label-caps-style text-nowrap text-on-surface-variant transition-colors duration-300 group-hover:text-background">
              {label}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</SparkleLayout>

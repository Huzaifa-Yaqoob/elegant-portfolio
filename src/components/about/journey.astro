---
import { getCollection, getEntry } from "astro:content"

const sectionEntry = await getEntry("section", "journey")
if (!sectionEntry) throw new Error("Journey section entry not found")
const { title, description } = sectionEntry.data

const milestones = await getCollection("journey")
milestones.sort((a, b) => a.data.order - b.data.order)
---

<section
  id="journey-section"
  class="relative min-h-screen overflow-hidden bg-deep-obsidian"
>
  <div class="absolute top-0 left-0 z-20 px-6 pt-20 lg:px-16 lg:pt-24">
    <h2 class="h1-style tracking-tighter text-foreground uppercase">
      {title}
    </h2>
    <p class="label-caps-style mt-6 flex items-center gap-4 text-outline">
      <span class="inline-block h-px w-12 bg-foreground"></span>
      {description}
    </p>
  </div>

  <div class="flex h-screen flex-col justify-center overflow-hidden">
    <div id="journey-track" class="flex items-center">
      <div class="w-1/2 flex-none"></div>

      <div
        class="relative flex flex-none items-start gap-[20vw] pr-[20vw] lg:gap-[30vw]"
      >
        <div
          class="pointer-events-none absolute top-[6px] left-0 h-px bg-border-structural"
          style="width: 100%"
        >
        </div>

        {
          milestones.map((m) => (
            <div class="journey-milestone group relative flex max-w-xs flex-none flex-col pt-16">
              <div class="absolute top-0 left-0 h-3 w-3 bg-foreground transition-transform duration-300 group-hover:scale-150" />

              <span class="pb-2 text-xs font-bold tracking-[0.3em] text-outline">
                {m.data.code}
              </span>

              <h3 class="text-2xl leading-none font-black tracking-tighter text-foreground uppercase lg:text-3xl">
                {m.data.title}
              </h3>

              <div class="journey-content mt-6 space-y-4 border-l-2 border-border-structural pl-6 transition-all duration-500 group-hover:border-foreground">
                <p class="text-sm font-bold tracking-wider text-foreground uppercase">
                  {m.data.date}
                </p>
                <p class="text-sm leading-relaxed text-on-surface-variant">
                  {m.data.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  #journey-track {
    will-change: transform;
  }

  .journey-milestone {
    will-change: transform, opacity;
  }
</style>

<script>
  import { gsap } from "../../lib/gsap"

  window.addEventListener("load", () => {
    const ScrollTrigger = gsap.core.globals().ScrollTrigger
    const track = document.getElementById("journey-track")
    const section = document.getElementById("journey-section")
    if (!track || !section || !ScrollTrigger) return

    // Prevent mobile address-bar resize jumps from forcing refresh mid-scroll.
    ScrollTrigger.config({ ignoreMobileResize: true })
    ScrollTrigger.getById("journey-track-pin")?.kill()

    const getScroll = () => Math.max(0, track.scrollWidth - window.innerWidth)

    const milestones = gsap.utils.toArray<HTMLElement>(".journey-milestone")
    const milestonesData = milestones.map((el) => ({
      el,
      content: el.querySelector<HTMLElement>(".journey-content"),
      offsetLeft: 0,
    }))

    const calcOffsets = () => {
      const trackRect = track.getBoundingClientRect()
      milestonesData.forEach((d) => {
        const rect = d.el.getBoundingClientRect()
        d.offsetLeft = rect.left - trackRect.left
      })
    }

    calcOffsets()

    gsap.to(track, {
      x: () => -getScroll(),
      ease: "none",
      scrollTrigger: {
        id: "journey-track-pin",
        trigger: section,
        pin: true,
        pinType: "transform",
        anticipatePin: 1,
        start: "top top",
        end: () => "+=" + getScroll(),
        scrub: true,
        fastScrollEnd: true,
        invalidateOnRefresh: true,
        onRefresh: calcOffsets,
        onUpdate: (self) => {
          const progress = Math.min(self.progress, 1)
          const totalScroll = getScroll()
          const currentX = -progress * totalScroll
          const vw = window.innerWidth
          const revealStart = vw * 1.1
          const revealEnd = vw * 0.75

          milestonesData.forEach(({ content, offsetLeft }) => {
            if (!content) return
            const mx = offsetLeft + currentX

            if (mx >= revealStart) {
              gsap.set(content, { opacity: 0, y: 40 })
            } else if (mx <= revealEnd) {
              gsap.set(content, { opacity: 1, y: 0 })
            } else {
              const p = (revealStart - mx) / (revealStart - revealEnd)
              gsap.set(content, { opacity: p, y: 40 * (1 - p) })
            }
          })
        },
      },
    })
  })
</script>

---
import LucideIcon from "@/components/icons/LucideIcon"

interface Props {
  quote: string
  name: string
  role: string
  image?: string
  imageAlt?: string
  tag?: string
}

const {
  quote,
  name,
  role,
  image,
  imageAlt = `${name} profile picture`,
  tag = "LOG_002",
} = Astro.props
---

<article
  class="group relative flex w-full flex-col gap-6 overflow-hidden border border-outline-variant bg-primary-fixed p-6 transition-colors duration-500 hover:bg-secondary md:gap-10 md:px-12 md:py-10"
>
  <div
    class="absolute top-0 right-0 border-b border-l border-outline-variant bg-surface px-2 py-1"
  >
    <span class="font-mono-code text-mono-code text-on-surface uppercase">
      {tag}
    </span>
  </div>

  <div class="flex grow items-center justify-center py-2 md:py-6">
    <p
      class="max-w-3xl text-center font-h3 text-xl leading-tight text-on-primary-fixed-variant md:text-h3"
    >
      "{quote}"
    </p>
  </div>

  <div class="mt-auto flex items-center gap-4">
    {
      image ? (
        <img
          src={image}
          alt={imageAlt}
          class="h-14 w-14 border border-surface object-cover grayscale transition-all duration-500 group-hover:grayscale-0"
          loading="lazy"
        />
      ) : (
        <div class="flex h-14 w-14 items-center justify-center border border-surface bg-surface text-on-surface">
          <LucideIcon name="User" size={24} />
        </div>
      )
    }
    <div class="flex flex-col">
      <span
        class="font-body-lg text-body-sm font-bold text-on-tertiary-fixed uppercase md:text-body-lg"
      >
        {name}
      </span>
      <span
        class="font-mono-code text-mono-code text-on-tertiary-container uppercase"
      >
        {role}
      </span>
    </div>
  </div>
</article>

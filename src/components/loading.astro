---

---

<div
  id="loading-screen"
  class="fixed inset-0 z-9999 flex flex-col items-center justify-center bg-deep-obsidian"
>
  <!-- Decorative diagonal lines (brand motif) -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div
      class="absolute top-1/3 left-0 h-px w-full origin-left bg-border-structural"
      style="transform: rotate(-3deg)"
    >
    </div>
    <div
      class="absolute top-2/3 left-0 h-px w-full origin-left bg-border-structural/60"
      style="transform: rotate(-3deg)"
    >
    </div>
  </div>

  <!-- Center content -->
  <div class="relative flex flex-col items-center gap-10">
    <!-- Monogram -->
    <div id="loading-mono-wrap" class="overflow-hidden">
      <span id="loading-mono" class="h1-style block text-secondary">H.</span>
    </div>

    <!-- Divider -->
    <div id="loading-divider" class="h-px w-24 bg-secondary/60"></div>

    <!-- Name -->
    <div id="loading-name-wrap" class="overflow-hidden">
      <p
        id="loading-name"
        class="label-caps-style tracking-[0.3em] text-secondary/40"
      >
        Huzaifa
      </p>
    </div>

    <!-- Loading squares (zero radius per design system) -->
    <div id="loading-indicator" class="mt-2 flex gap-3">
      <span class="loading-dot block size-1.5 bg-secondary/20"></span>
      <span class="loading-dot block size-1.5 bg-secondary/20"></span>
      <span class="loading-dot block size-1.5 bg-secondary/20"></span>
    </div>
  </div>
</div>

<noscript>
  <style>
    #loading-screen {
      display: none !important;
    }
  </style>
</noscript>

<script>
  import { gsap } from "@/lib/gsap"

  const screen = document.getElementById("loading-screen")
  if (!screen) throw new Error("Loading screen element not found")

  const monoWrap = document.getElementById("loading-mono-wrap")
  const divider = document.getElementById("loading-divider")
  const nameWrap = document.getElementById("loading-name-wrap")
  const dots = document.querySelectorAll<HTMLElement>(".loading-dot")

  if (!monoWrap || !divider || !nameWrap)
    throw new Error("Loading elements not found")

  const startDotsAnimation = () => {
    gsap.to(dots, {
      scale: 2,
      opacity: 1,
      backgroundColor: "var(--color-secondary)",
      duration: 0.5,
      stagger: 0.15,
      repeat: -1,
      yoyo: true,
      ease: "power1.inOut",
    })
  }

  // --- Exit Logic (no artificial minimum — exits immediately when page is ready) ---
  const hide = (instant: boolean) => {
    gsap.killTweensOf(dots)
    gsap.set(dots, { clearProps: "all" })

    if (instant) {
      screen.style.display = "none"
    } else {
      gsap.to(screen, {
        autoAlpha: 0,
        scale: 0.96,
        duration: 0.3,
        ease: "power2.inOut",
        onComplete: () => {
          screen.style.display = "none"
        },
      })
    }
  }

  const exit = (instant: boolean) => {
    ;(window as any).__loadingComplete = true
    window.dispatchEvent(new CustomEvent("loading:exiting"))
    hide(instant)
  }

  // If page is already loaded, exit instantly — no loading screen
  if (document.readyState === "complete") {
    exit(true)
  } else {
    // Page still loading — keep text static, animate only dots
    startDotsAnimation()
    window.addEventListener("load", () => exit(false))
  }

  // Fallback: force-dismiss after 8s
  gsap.delayedCall(8, () => exit(true))
</script>

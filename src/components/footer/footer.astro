---
import { getEntry } from "astro:content"
import GithubIcon from "@/components/icons/tech_stack/github.astro"
import XIcon from "@/components/icons/tech_stack/x.astro"
import InstagramIcon from "@/components/icons/tech_stack/instagram.astro"
import FacebookIcon from "@/components/icons/tech_stack/facebook.astro"
import DiscordIcon from "@/components/icons/tech_stack/discord.astro"
import WhatsAppIcon from "@/components/icons/tech_stack/whatsapp.astro"

const navEntry = await getEntry("nav", "nav")
if (!navEntry) throw new Error("Navigation configuration not found")

const siteEntry = await getEntry("site", "site")
if (!siteEntry) throw new Error("Site configuration not found")

const { footer } = navEntry.data
const { personal, social } = siteEntry.data

const currentYear = new Date().getFullYear()
const copyrightText = footer.copyright.replace("{year}", currentYear.toString())

const iconMap: Record<string, typeof GithubIcon> = {
  github: GithubIcon,
  x: XIcon,
  instagram: InstagramIcon,
  facebook: FacebookIcon,
  discord: DiscordIcon,
  whatsapp: WhatsAppIcon,
}

const labelMap: Record<string, string> = {
  github: "GitHub",
  x: "X [TWITTER]",
  instagram: "Instagram",
  facebook: "Facebook",
  discord: "Discord",
  whatsapp: "WhatsApp",
}
---

<footer class="relative overflow-hidden pt-24 pb-12">
  <div class="mb-10 h-0.5 w-full -rotate-1 bg-border"></div>
  <div class="relative z-10 mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-8">
      <!-- Brand, Copyright & Tagline -->
      <div class="flex flex-col gap-2">
        <p class="font-heading text-5xl font-black tracking-tighter text-primary uppercase md:text-7xl">
          {personal.name}
        </p>
        <p class="body-sm-style text-on-surface-variant">
          {copyrightText}
        </p>
        {
          footer.tagline && (
            <p class="body-sm-style mt-2 max-w-xs text-on-surface-variant">
              {footer.tagline}
            </p>
          )
        }
      </div>

      <!-- Contact Information -->
      <div class="flex flex-col gap-4">
        <h3 class="h3-style text-primary uppercase">Contact</h3>
        <a
          href={`mailto:${personal.email}`}
          class="body-lg-style relative w-fit text-on-surface after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-primary after:origin-right after:scale-x-0 after:transition-transform after:duration-300 hover:text-primary hover:after:origin-left hover:after:scale-x-100"
        >
          {personal.email}
        </a>
        <a
          href={`tel:${personal.phone}`}
          class="body-lg-style relative w-fit text-on-surface after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-primary after:origin-right after:scale-x-0 after:transition-transform after:duration-300 hover:text-primary hover:after:origin-left hover:after:scale-x-100"
        >
          {personal.phone}
        </a>
        <a
          href={personal.address_link}
          target="_blank"
          rel="noopener noreferrer"
          class="body-lg-style relative w-fit text-on-surface after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:bg-primary after:origin-right after:scale-x-0 after:transition-transform after:duration-300 hover:text-primary hover:after:origin-left hover:after:scale-x-100"
        >
          {personal.address}
        </a>
      </div>

      <!-- Social Links -->
      <div class="flex flex-col gap-4">
        <h3 class="h3-style text-primary uppercase">Connect</h3>
        <div class="flex flex-wrap gap-4">
          {
            Object.entries(social).map(([platform, url]) => {
              const Icon = iconMap[platform]
              return (
                <a
                  href={url as string}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="label-caps-style inline-flex items-center justify-center gap-2 border-2 border-border bg-transparent px-4 py-2 text-on-surface uppercase transition-colors duration-300 hover:bg-on-surface hover:text-background"
                >
                  {Icon && <Icon class="h-4 w-4" />}
                  {labelMap[platform] || platform}
                </a>
              )
            })
          }
        </div>
      </div>
    </div>
  </div>
</footer>

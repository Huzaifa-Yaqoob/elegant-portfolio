---
import { getCollection } from "astro:content"
import LucideIcon from "@/components/icons/LucideIcon"

const entries = await getCollection("portfolio")
const projects = entries.sort((a, b) => a.data.order - b.data.order)
---

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: projects.map((project, i) => ({
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "CreativeWork",
        name: project.data.title,
        description: project.data.description,
        url: project.data.url || undefined,
      },
    })),
  })}
/>

<div id="portfolio-showcase" class="flex w-full flex-col">
  {
    projects.map((project, index) => {
      const isEven = index % 2 === 0
      const tools = project.data.tools
      const projectNumber = String(index + 1).padStart(2, "0")

      return (
        <section
          class={`showcase-section relative w-full border-b border-surface-variant px-8 py-32 lg:px-16 ${
            !isEven ? "bg-surface-container-lowest" : ""
          }`}
        >
          <div
            class={`flex flex-col items-center gap-8 lg:flex-row ${
              !isEven ? "lg:flex-row-reverse" : ""
            }`}
          >
            {/* Image Container */}
            <div
              data-speed-sm="0.9"
              data-speed-lg="0.85"
              class="skew-target relative w-full overflow-hidden border border-surface-variant lg:w-3/5"
            >
              <div class="h-70 w-full md:h-112.5 lg:h-162.5">
                <img
                  src={project.data.mainImage}
                  alt={project.data.title}
                  class="h-full w-full object-cover grayscale transition-all duration-700 hover:grayscale-0"
                  loading="lazy"
                />
              </div>
            </div>

            {/* Info Card - Overlapping */}
            <div
              data-speed-sm="1.05"
              data-speed-lg="1.1"
              class={`skew-target relative z-10 w-full border border-surface-variant bg-background p-10 shadow-2xl lg:w-2/5 ${
                isEven ? "lg:-ml-32" : "lg:-mr-32"
              }`}
            >
              <div class="counter-skew-content">
                <div class="mb-4 flex items-start justify-between gap-4">
                  <span class="block font-heading text-6xl font-black tracking-tighter text-surface-variant">
                    {projectNumber}
                  </span>
                  <a
                    href={`/my-work/${project.data.slug}`}
                    aria-label={`Open ${project.data.title} project`}
                    class="group/action inline-flex shrink-0 items-center justify-center border border-on-surface text-on-surface transition-colors duration-300 hover:bg-on-surface hover:text-background"
                  >
                    <LucideIcon
                      name="ArrowUpRight"
                      size={18}
                      class="transition-transform duration-300 group-hover/action:translate-x-0.5 group-hover/action:-translate-y-0.5"
                    />
                  </a>
                </div>
                <h2 class="mb-6 font-heading text-4xl font-black tracking-tighter text-on-background uppercase">
                  {project.data.title}
                </h2>
                <p class="mb-10 line-clamp-5 leading-relaxed text-on-surface-variant">
                  {project.data.description}
                </p>
                <div class="flex flex-wrap gap-2">
                  {tools.slice(0, 4).map((tool) => (
                    <span class="border border-surface-variant px-3 py-1.5 text-xs font-bold tracking-widest uppercase">
                      {tool}
                    </span>
                  ))}
                  {tools.length > 4 && (
                    <span class="border border-surface-variant px-3 py-1.5 text-xs font-bold tracking-widest uppercase">
                      +{tools.length - 4} more
                    </span>
                  )}
                </div>
              </div>
            </div>
          </div>
        </section>
      )
    })
  }
</div>

<script>
  import { gsap } from "@/lib/gsap"
  import { ScrollSmoother } from "gsap/ScrollSmoother"
  import { ScrollTrigger } from "gsap/ScrollTrigger"

  function applyResponsiveSpeeds() {
    const isLg = window.matchMedia("(min-width: 1024px)").matches
    const speedAttr = isLg ? "data-speed-lg" : "data-speed-sm"

    document.querySelectorAll<HTMLElement>("[data-speed-lg]").forEach((el) => {
      el.setAttribute("data-speed", el.getAttribute(speedAttr) || "1")
    })

    ScrollTrigger.refresh()
  }

  applyResponsiveSpeeds()
  window
    .matchMedia("(min-width: 1024px)")
    .addEventListener("change", applyResponsiveSpeeds)

  function getScrollPos(): number {
    const s = ScrollSmoother.get()
    return s ? s.scrollTop() : window.scrollY
  }

  const cards = document.querySelectorAll<HTMLElement>(".skew-target")
  const counters = document.querySelectorAll<HTMLElement>(
    ".counter-skew-content"
  )

  if (cards.length) {
    let lastPos = getScrollPos()
    const multiplier = 0.08

    const tick = () => {
      const pos = getScrollPos()
      const v = pos - lastPos
      lastPos = pos

      if (Math.abs(v) > 0.5) {
        const skew = gsap.utils.clamp(-8, 8, v * multiplier)
        gsap.set(cards, { skewY: skew })
        gsap.set(counters, { skewY: -skew })
      } else {
        gsap.set(cards, { skewY: 0 })
        gsap.set(counters, { skewY: 0 })
      }
    }

    gsap.ticker.add(tick)
  }
</script>

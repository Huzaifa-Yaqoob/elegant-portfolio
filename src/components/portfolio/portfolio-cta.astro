---
import { buttonVariants } from "@/lib/button-variants.ts"
import { cn } from "@/lib/utils"
import LucideIcon from "@/components/icons/LucideIcon"
---

<div class="mt-16 flex justify-center">
  <a
    href="/portfolio"
    id="magnetic-portfolio-cta"
    class={cn(
      buttonVariants({ variant: "outline", size: "lg" }),
      "border-2 border-on-surface px-12 py-8 font-heading text-sm text-on-surface uppercase"
    )}
  >
    View All Projects
    <LucideIcon
      name="ArrowRight"
      size={18}
      class="transition-transform group-hover/button:translate-x-0.5"
    />
  </a>
</div>

<script>
  import { gsap } from "@/lib/gsap"

  window.addEventListener("load", () => {
    const magneticBtn = document.getElementById("magnetic-portfolio-cta")
    if (magneticBtn) {
      const STRENGTH = 0.8
      const DISTANCE = 150

      const setCursorState = (state: string) => {
        window.dispatchEvent(
          new CustomEvent("cursor-state-change", { detail: { state } })
        )
      }

      const handleMouseMove = (e: MouseEvent) => {
        const rect = magneticBtn.getBoundingClientRect()
        const centerX = rect.left + rect.width / 2
        const centerY = rect.top + rect.height / 2

        const deltaX = e.clientX - centerX
        const deltaY = e.clientY - centerY
        const dist = Math.sqrt(deltaX * deltaX + deltaY * deltaY)

        if (dist < DISTANCE) {
          const factor = (1 - dist / DISTANCE) * STRENGTH
          const moveX = deltaX * factor
          const moveY = deltaY * factor

          magneticBtn.style.transform = `translate(${moveX}px, ${moveY}px)`
        } else {
          magneticBtn.style.transform = "translate(0px, 0px)"
        }
      }

      const handleMouseEnter = () => {
        setCursorState("hidden")
      }

      const handleMouseLeave = () => {
        magneticBtn.style.transform = "translate(0px, 0px)"
        setCursorState("default")
      }

      magneticBtn.addEventListener("mouseenter", handleMouseEnter)
      document.addEventListener("mousemove", handleMouseMove)
      magneticBtn.addEventListener("mouseleave", handleMouseLeave)
    }
  })
</script>

---
import LucideIcon from "@/components/icons/LucideIcon"

export interface Props {
  title: string
  description: string
  url?: string
  tools: string[]
  role?: string
  timeline?: string
  company?: string
  companyUrl?: string
  images?: string[]
}

const {
  title,
  description,
  url,
  tools,
  role,
  timeline,
  company,
  companyUrl,
  images,
} = Astro.props

const mockupImage = images?.[0] ?? "/projects/background.png"
const isRestricted = mockupImage === "/projects/background.png"
---

<header
  id="project-header"
  class="relative flex min-h-dvh w-full flex-col border-b border-surface-variant"
>
  <div
    id="project-header-bg"
    class="absolute inset-0 bg-(image:--bg-image) bg-cover bg-center"
    style="--bg-image: url('/projects/background.png')"
  >
    {
      !isRestricted && (
        <img
          src={mockupImage}
          alt={title}
          class="absolute inset-0 h-full w-full object-contain object-top pt-28 md:object-center md:pt-0"
        />
      )
    }
    <div
      class="absolute inset-0 bg-linear-to-t from-background/95 via-background/70 to-background/40"
    >
    </div>
  </div>

  <div
    id="project-header-meta"
    class="relative z-10 mx-auto hidden w-full max-w-7xl flex-col gap-6 px-6 pt-24 md:flex md:px-16 md:pt-40"
  >
    {
      (role || timeline || company) && (
        <div class="flex flex-wrap gap-x-10 gap-y-3">
          {company && (
            <div>
              <span class="font-heading text-xs font-semibold tracking-widest text-outline uppercase">
                Company
              </span>
              {companyUrl ? (
                <a
                  href={companyUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-1 flex items-center gap-1.5 text-base font-semibold text-on-surface transition-colors duration-300 hover:text-primary"
                >
                  {company}
                  <LucideIcon name="ArrowUpRight" size={14} />
                </a>
              ) : (
                <p class="mt-1 text-base font-semibold text-on-surface">
                  {company}
                </p>
              )}
            </div>
          )}
          {role && (
            <div>
              <span class="font-heading text-xs font-semibold tracking-widest text-outline uppercase">
                Role
              </span>
              <p class="mt-1 text-base font-semibold text-on-surface">{role}</p>
            </div>
          )}
          {timeline && (
            <div>
              <span class="font-heading text-xs font-semibold tracking-widest text-outline uppercase">
                Timeline
              </span>
              <p class="mt-1 text-base font-semibold text-on-surface">
                {timeline}
              </p>
            </div>
          )}
        </div>
      )
    }

    <nav class="flex w-full flex-wrap gap-2">
      {
        tools
          .slice(0, 6)
          .map((tool) => (
            <span class="border border-on-surface/30 px-3 py-1.5 font-heading text-xs font-semibold tracking-widest text-on-surface/80 uppercase backdrop-blur-sm">
              {tool}
            </span>
          ))
      }
      {
        tools.length > 6 && (
          <span class="border border-on-surface/30 px-3 py-1.5 font-heading text-xs font-semibold tracking-widest text-on-surface/80 uppercase backdrop-blur-sm">
            +{tools.length - 6} more
          </span>
        )
      }
    </nav>
  </div>

  <div
    id="project-header-content"
    class="relative z-10 mx-auto mt-auto flex w-full max-w-7xl flex-col px-6 pb-16 md:px-16 md:pb-20 lg:pb-28"
  >
    <div class="flex flex-col items-start justify-between gap-8 md:flex-row">
      <div class="max-w-3xl">
        <h1 class="h1-style text-on-background uppercase">
          {title}
        </h1>
        <p
          class="mt-6 max-w-2xl text-lg leading-relaxed font-medium tracking-wide text-on-surface-variant"
        >
          {description}
        </p>
      </div>

      {
        url && (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="group/action mt-2 inline-flex shrink-0 items-center gap-2 border border-on-surface px-6 py-3 font-heading text-sm font-semibold tracking-widest text-on-surface uppercase transition-colors duration-300 hover:bg-on-surface hover:text-background"
          >
            Visit Site
            <LucideIcon
              name="ArrowUpRight"
              size={16}
              class="transition-transform duration-300 group-hover/action:translate-x-0.5 group-hover/action:-translate-y-0.5"
            />
          </a>
        )
      }
    </div>
  </div>
</header>

<!-- Meta & Tools for Mobile -->
<div
  id="project-header-mobile-meta"
  class="flex flex-col gap-6 border-b border-surface-variant bg-background px-6 py-8 md:hidden"
>
  {
    (role || timeline || company) && (
      <div class="flex flex-wrap gap-x-10 gap-y-3">
        {company && (
          <div>
            <span class="font-heading text-xs font-semibold tracking-widest text-outline uppercase">
              Company
            </span>
            {companyUrl ? (
              <a
                href={companyUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-1 flex items-center gap-1.5 text-base font-semibold text-on-surface transition-colors duration-300 hover:text-primary"
              >
                {company}
                <LucideIcon name="ArrowUpRight" size={14} />
              </a>
            ) : (
              <p class="mt-1 text-base font-semibold text-on-surface">
                {company}
              </p>
            )}
          </div>
        )}
        {role && (
          <div>
            <span class="font-heading text-xs font-semibold tracking-widest text-outline uppercase">
              Role
            </span>
            <p class="mt-1 text-base font-semibold text-on-surface">{role}</p>
          </div>
        )}
        {timeline && (
          <div>
            <span class="font-heading text-xs font-semibold tracking-widest text-outline uppercase">
              Timeline
            </span>
            <p class="mt-1 text-base font-semibold text-on-surface">
              {timeline}
            </p>
          </div>
        )}
      </div>
    )
  }

  <nav class="flex w-full flex-wrap gap-2">
    {
      tools
        .slice(0, 6)
        .map((tool) => (
          <span class="border border-on-surface/30 px-3 py-1.5 font-heading text-xs font-semibold tracking-widest text-on-surface/80 uppercase backdrop-blur-sm">
            {tool}
          </span>
        ))
    }
    {
      tools.length > 6 && (
        <span class="border border-on-surface/30 px-3 py-1.5 font-heading text-xs font-semibold tracking-widest text-on-surface/80 uppercase backdrop-blur-sm">
          +{tools.length - 6} more
        </span>
      )
    }
  </nav>
</div>

<script>
  import { gsap } from "@/lib/gsap"

  const animate = () => {
    const bg = document.getElementById("project-header-bg")
    const meta = document.getElementById("project-header-meta")
    const content = document.getElementById("project-header-content")
    const mobileMeta = document.getElementById("project-header-mobile-meta")

    const tl = gsap.timeline({ defaults: { ease: "power3.out" } })

    if (bg) {
      tl.fromTo(
        bg,
        { yPercent: -100, opacity: 0 },
        { yPercent: 0, opacity: 1, duration: 1 },
        0
      )
    }

    if (meta) {
      tl.fromTo(
        meta,
        { y: 80, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.8 },
        0.15
      )
    }

    if (content) {
      tl.fromTo(
        content,
        { y: 120, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.8 },
        0.25
      )
    }

    if (mobileMeta) {
      tl.fromTo(
        mobileMeta,
        { y: 60, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6 },
        0.35
      )
    }
  }

  if ((window as any).__loadingComplete) {
    animate()
  } else {
    window.addEventListener("loading:exiting", animate, { once: true })
  }
</script>

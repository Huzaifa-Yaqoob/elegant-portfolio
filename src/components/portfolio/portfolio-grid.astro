---
import { getCollection, getEntry } from "astro:content"
import LucideIcon from "@/components/icons/LucideIcon"
import { resolveImage } from "@/lib/images"

const portfolioSection = await getEntry("section", "portfolio")
const maxPortfolio =
  typeof portfolioSection?.data?.max_portfolio === "number"
    ? portfolioSection.data.max_portfolio
    : 4

const entries = await getCollection("portfolio")
const projects = entries
  .sort((a, b) => b.data.order - a.data.order)
  .slice(0, maxPortfolio)

const cardClasses = [
  "md:col-span-8 min-h-[460px] bg-surface-dim hover:bg-surface-container-low",
  "md:col-span-4 min-h-[460px] bg-inverse-surface hover:bg-primary-fixed",
  "md:col-span-5 min-h-[420px] bg-surface-dim hover:bg-surface-container-low",
  "md:col-span-7 min-h-[420px] bg-background hover:bg-surface",
]
---

<div id="portfolio-grid" class="mt-16 grid grid-cols-1 gap-6 md:grid-cols-12">
  {
    projects.map((project, index) => {
      const tools = project.data.tools
      const isLightCard = index % cardClasses.length === 1
      const cardClass =
        cardClasses[index % cardClasses.length] ??
        "md:col-span-6 min-h-[520px] bg-surface-dim hover:bg-surface-container-low"

      return (
        <article
          class={`group relative flex flex-col overflow-hidden border border-surface-variant transition-colors duration-300 ${cardClass}`}
        >
          <div
            class="relative flex flex-1 flex-col overflow-hidden border-b border-surface-variant bg-surface-container-low bg-cover bg-center"
            style={`background-image: url(${resolveImage("/projects/background.png")!.src})`}
          >
            {project.data.mainImage === "/projects/background.png" ? (
              <div class="flex flex-1 items-center justify-center p-3">
                <span class="label-data-style tracking-widest text-outline/40 uppercase">
                  Preview Restricted
                </span>
              </div>
            ) : (
              <div class="flex flex-1 p-3">
                <img
                  src={resolveImage(project.data.mainImage)?.src ?? resolveImage("/projects/background.png")!.src}
                  alt={project.data.title}
                  class="relative z-10 h-full w-full object-contain"
                  loading="lazy"
                />
              </div>
            )}
            <div class="absolute top-6 left-6 border border-outline bg-surface/85 px-3 py-1 backdrop-blur">
              <span class="label-caps-style text-on-surface">
                {project.data.slug}
              </span>
            </div>
          </div>

          <div class="flex flex-col p-5 md:p-6">
            <div>
              <div class="mb-3 flex items-start justify-between gap-4">
                <h3
                  class={`h3-style uppercase ${isLightCard ? "text-inverse-on-surface" : "text-on-surface"}`}
                >
                  {project.data.title}
                </h3>
                <a
                  href={`/my-work/${project.data.slug}`}
                  aria-label={`Open ${project.data.title} project`}
                  class={`group/action inline-flex size-10 shrink-0 items-center justify-center border transition-colors duration-300 ${
                    isLightCard
                      ? "border-inverse-on-surface text-inverse-on-surface hover:bg-inverse-on-surface hover:text-inverse-surface"
                      : "border-on-surface text-on-surface hover:bg-on-surface hover:text-background"
                  }`}
                >
                  <LucideIcon
                    name="ArrowUpRight"
                    size={18}
                    class="transition-transform duration-300 group-hover/action:translate-x-0.5 group-hover/action:-translate-y-0.5"
                  />
                </a>
              </div>
              <p
                class={`line-clamp-5 body-sm-style ${isLightCard ? "text-on-primary" : "text-on-surface-variant"}`}
              >
                {project.data.description}
              </p>
            </div>

            <div class="mt-4 flex flex-wrap gap-2">
              {tools.map((tool) => (
                <span
                  class={`px-2 py-1 label-data-style uppercase ${isLightCard ? "border border-outline text-inverse-on-surface" : "border border-surface-variant text-outline"}`}
                >
                  {tool}
                </span>
              ))}
            </div>
          </div>
        </article>
      )
    })
  }
</div>

<script>
  import { initSkewScroll } from "@/components/animation/skew-scroll"

  initSkewScroll("#portfolio-grid > article")
</script>

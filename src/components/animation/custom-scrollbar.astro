---

---

<div
  id="custom-scrollbar"
  class="fixed top-1/2 right-3 z-50 hidden -translate-y-1/2 md:block"
  style="height: clamp(200px, 40vh, 400px)"
>
  <div class="relative h-full w-0.5 bg-surface-container-high">
    <div
      id="scrollbar-thumb"
      class="absolute left-1/2 w-2.5 -translate-x-1/2 cursor-grab bg-on-surface-variant active:cursor-grabbing"
    >
    </div>
  </div>
</div>

<script>
  import { gsap } from "@/lib/gsap"
  import { setCursorState } from "@/components/cursor"
  import { ScrollTrigger } from "gsap/ScrollTrigger"
  import { ScrollSmoother } from "gsap/ScrollSmoother"

  gsap.registerPlugin(ScrollSmoother)
  ;(function boot() {
    const smoother = ScrollSmoother.get()
    if (!smoother) {
      requestAnimationFrame(boot)
      return
    }

    const bar = document.getElementById("custom-scrollbar")!
    const thumb = document.getElementById("scrollbar-thumb")!
    const content = document.getElementById("smooth-content")!

    let isDragging = false

    function updateThumb(progress: number) {
      const trackH = bar.offsetHeight
      const totalH = content.offsetHeight
      const viewportH = window.innerHeight
      const thumbH = Math.max(24, trackH * (viewportH / totalH))
      const thumbT = progress * (trackH - thumbH)

      thumb.style.height = `${thumbH}px`
      thumb.style.top = `${thumbT}px`
    }

    function scrollToClientY(clientY: number) {
      const trackRect = bar.getBoundingClientRect()
      const trackH = bar.offsetHeight
      const thumbH = thumb.offsetHeight
      const available = trackH - thumbH

      let thumbTop = clientY - trackRect.top - thumbH / 2
      thumbTop = Math.max(0, Math.min(available, thumbTop))

      const progress = available > 0 ? thumbTop / available : 0
      const totalScroll = content.offsetHeight - window.innerHeight

      smoother!.scrollTop(progress * totalScroll)
      updateThumb(progress)
    }

    function onPointerDown(e: PointerEvent) {
      const isThumb = e.target === thumb || thumb.contains(e.target as Node)
      if (!isThumb) scrollToClientY(e.clientY)

      isDragging = true
      setCursorState("hidden", { x: e.clientX, y: e.clientY })
      thumb.classList.add("bg-on-surface")
      thumb.classList.remove("bg-on-surface-variant")
      document.body.style.userSelect = "none"
      e.preventDefault()
    }

    function onPointerMove(e: PointerEvent) {
      if (!isDragging) return
      setCursorState("hidden", { x: e.clientX, y: e.clientY })
      scrollToClientY(e.clientY)
    }

    function onPointerUp(e: PointerEvent) {
      if (!isDragging) return
      isDragging = false
      thumb.classList.remove("bg-on-surface")
      thumb.classList.add("bg-on-surface-variant")
      setCursorState(bar.matches(":hover") ? "grab" : "default", {
        x: e.clientX,
        y: e.clientY,
      })
      document.body.style.userSelect = ""
    }

    function onEnter() {
      if (!isDragging) setCursorState("grab")
    }

    function onLeave() {
      if (!isDragging) setCursorState("default")
    }

    bar.addEventListener("pointerdown", onPointerDown)
    bar.addEventListener("pointerenter", onEnter)
    bar.addEventListener("pointerleave", onLeave)
    document.addEventListener("pointermove", onPointerMove)
    document.addEventListener("pointerup", onPointerUp)

    ScrollTrigger.create({
      trigger: "#smooth-content",
      start: "top top",
      end: "bottom bottom",
      onUpdate: (self) => {
        if (!isDragging) updateThumb(self.progress)
      },
    })

    const currentScroll = smoother.scrollTop()
    const maxScroll = content.offsetHeight - window.innerHeight
    const initialProgress = maxScroll > 0 ? currentScroll / maxScroll : 0
    updateThumb(initialProgress)
  })()
</script>

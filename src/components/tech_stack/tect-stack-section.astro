---
import { getEntry } from "astro:content"
import TectStackGrid from "./tect-stack-grid.astro"

const techStackSection = await getEntry("section", "tech-stack")

if (!techStackSection) {
  console.error(
    "Section entry 'tech-stack.md' not found in content collection 'section'."
  )
  return ""
}

const { title, description, tag, core_strengths, technologies } =
  techStackSection.data
---

<section
  id="tech-stack-section"
  class="relative my-16 border-y border-border-structural bg-surface-container-lowest py-20"
>
  <div class="mx-auto px-6 lg:px-16">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:gap-6">
      <div
        id="tech-stack-left"
        class="w-full shrink-0 border-l border-border-structural pl-6 lg:w-1/3 lg:pr-10"
      >
        <p class="mb-4 font-mono-label text-mono-label text-primary uppercase">
          {tag}
        </p>
        <h2 class="h2-style mb-6 text-on-surface uppercase">
          {title.split(" ")[0]}<br />{title.split(" ").slice(1).join(" ")}
        </h2>
        <p class="body-lg-style text-on-surface-variant">{description}</p>

        <div class="mt-6 border-t border-border-structural pt-5">
          <p
            class="mb-3 font-mono-label text-mono-label text-on-surface uppercase"
          >
            Engineering Focus
          </p>
          <div class="flex flex-wrap gap-2">
            {
              (core_strengths ?? []).map((item: string) => (
                <span class="border border-surface-variant px-2 py-1 font-mono-code text-mono-code text-on-surface-variant uppercase">
                  {item}
                </span>
              ))
            }
          </div>
        </div>
      </div>

      <div class="w-full lg:w-2/3 lg:min-w-0">
        <TectStackGrid technologies={technologies ?? []} />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "@/lib/gsap"
  import { ScrollTrigger } from "gsap/ScrollTrigger"

  gsap.matchMedia().add("(min-width: 1024px)", () => {
    ScrollTrigger.create({
      trigger: "#tech-stack-section",
      start: "top top",
      end: "bottom bottom",
      pin: "#tech-stack-left",
      pinSpacing: true,
    })
  })
</script>

---
import { getEntry, getCollection } from "astro:content"
import Divider from "@/components/divider.astro"
import ServiceCard from "@/components/service/service_card.astro"

// Fetch the service section data using getEntry
const serviceSection = await getEntry("section", "service")

// Handle case where serviceSection might not be found
if (!serviceSection) {
  console.error(
    "Service section entry 'service.md' not found in content collection 'section'."
  )
  // Render nothing or a fallback UI if the service section is critical
  // For a component, returning an empty fragment is often appropriate.
  return ""
}

const { title, description, divider_text, badge } = serviceSection.data

// Fetch all service entries from the 'serviices' collection
const services = await getCollection("services")

// Sort services by the 'order' property
services.sort((a, b) => a.data.order - b.data.order)
---

<section class="px-6 py-10 lg:px-16">
  <div class="m flex flex-col justify-between md:flex-row lg:items-end">
    <h2 class="h1-style mb-6 text-on-surface uppercase">
      {title.split(" ")[0]}<br />{title.split(" ").slice(1).join(" ")}
    </h2>
    <div class="flex flex-col justify-end text-right md:col-span-4">
      <p
        class="mb-4 font-mono-code text-mono-code tracking-widest text-outline uppercase"
      >
        [ {badge} ]
      </p>
      <p
        class="ml-auto max-w-sm font-body-lg text-body-lg text-on-surface-variant"
      >
        {description}
      </p>
    </div>
  </div>
  {divider_text && <Divider text={divider_text} />}

  <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
    {
      services.map((service) => (
        <ServiceCard
          number={service.data.number}
          icon={service.data.icon}
          title={service.data.title}
          description={service.data.description}
          tags={service.data.tags}
        />
      ))
    }
  </div>
</section>

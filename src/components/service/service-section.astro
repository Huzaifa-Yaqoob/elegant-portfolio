---
import { getCollection, getEntry } from "astro:content"

// Fetch the service section data using getEntry
const serviceSection = await getEntry("section", "service")

// Handle case where serviceSection might not be found
if (!serviceSection) {
  console.error(
    "Service section entry 'service.md' not found in content collection 'section'."
  )
  // Render nothing or a fallback UI if the service section is critical
  // For a component, returning an empty fragment is often appropriate.
  return ""
}

const { title, description, divider_text, badge } = serviceSection.data
---

<section class="mx-auto flex items-end justify-between px-6 py-10 lg:px-16">
  <h2 class="h1-style mb-6 text-on-surface uppercase">
    {title.split(" ")[0]}<br />{title.split(" ").slice(1).join(" ")}
  </h2>
  <div class="flex flex-col justify-end text-right md:col-span-4">
    <p
      class="font-mono-code text-mono-code mb-4 tracking-widest text-outline uppercase"
    >
      [ {badge} ]
    </p>
    <p
      class="font-body-lg text-body-lg ml-auto max-w-sm text-on-surface-variant"
    >
      {description}
    </p>
  </div>
</section>

---
import { getEntry } from "astro:content"
import { buttonVariants } from "@/lib/button-variants"
import { cn } from "@/lib/utils"

const navEntry = await getEntry("nav", "nav")
if (!navEntry) throw new Error("Navigation configuration not found")

const siteEntry = await getEntry("site", "site")
if (!siteEntry) throw new Error("Site configuration not found")
const { personal } = siteEntry.data

const { header } = navEntry.data
const currentPath = Astro.url.pathname

const normalizePath = (path: string) => {
  if (!path) return "/"
  const withoutTrailing = path.replace(/\/+$/, "")
  return withoutTrailing === "" ? "/" : withoutTrailing
}

const isLinkActive = (href: string) =>
  normalizePath(href) === normalizePath(currentPath)
---

<header
  id="main-nav"
  class="fixed top-0 left-0 z-50 w-full border-b border-transparent mix-blend-difference transition-all duration-300 ease-in-out"
  data-theme="dark"
>
  <div
    id="nav-glass"
    class="pointer-events-none absolute inset-0 -z-10 border-b border-transparent transition-all duration-300"
  >
  </div>
  <div
    id="nav-container"
    class="relative z-10 mx-auto flex items-center justify-between px-6 py-8 transition-all duration-300 lg:px-16"
  >
    <!-- Logo -->
    <a
      href={header.logo.href}
      class="group font-heading text-2xl leading-none font-extrabold tracking-tighter uppercase"
    >
      <span class="text-foreground transition-colors group-hover:text-primary">
        {
          header.logo.label
            .split(".")
            .map((part: string, i: number, arr: string[]) => (
              <>
                {part}
                {i < arr.length - 1 && <span class="text-primary">.</span>}
              </>
            ))
        }
      </span>
    </a>

    <!-- Main Links - Desktop Only for now -->
    <nav class="hidden items-center gap-10 lg:flex">
      {
        header.links.map((link: { label: string; href: string }) => (
          <a
            href={link.href}
            data-nav-link
            data-link-label={link.label}
            data-active={isLinkActive(link.href) ? "true" : "false"}
            class={cn(
              buttonVariants({ variant: "ghost", size: "sm" }),
              "label-caps-style text-foreground hover:bg-transparent focus-visible:bg-transparent active:bg-transparent aria-expanded:bg-transparent dark:hover:bg-transparent dark:aria-expanded:bg-transparent"
            )}
          >
            <span data-nav-link-text>
              {isLinkActive(link.href) ? `[${link.label}]` : link.label}
            </span>
          </a>
        ))
      }
    </nav>

    <!-- Mobile Toggle -->
    <button
      id="mobile-toggle"
      class="relative z-50 flex h-10 w-10 flex-col items-center justify-center gap-1.5 lg:hidden"
      aria-label="Toggle Menu"
    >
      <span class="line-1 h-0.5 w-6 bg-foreground transition-all duration-300"
      ></span>
      <span class="line-2 h-0.5 w-6 bg-foreground transition-all duration-300"
      ></span>
      <span class="line-3 h-0.5 w-6 bg-foreground transition-all duration-300"
      ></span>
    </button>

    <!-- CTA Button -->
    <div class="hidden lg:block">
      <a
        href={header.cta.href}
        id="magnetic-cta-btn"
        class={cn(
          buttonVariants({ variant: "outline" }),
          "isolate mix-blend-normal"
        )}
      >
        {header.cta.label}
      </a>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 flex translate-y-full flex-col overflow-y-auto bg-background pt-24 lg:hidden"
>
  <nav class="flex flex-col gap-6 px-8 py-12">
    {
      header.links.map((link: { label: string; href: string }) => (
        <a
          href={link.href}
          data-nav-link
          data-link-label={link.label}
          data-active={isLinkActive(link.href) ? "true" : "false"}
          class="h1-style text-foreground uppercase transition-colors hover:bg-transparent hover:text-primary"
        >
          <span data-nav-link-text>
            {isLinkActive(link.href) ? `[${link.label}]` : link.label}
          </span>
        </a>
      ))
    }
  </nav>

  <div class="mt-auto flex flex-col gap-10 px-8 pb-12">
    <a
      href={header.cta.href}
      class={cn(
        buttonVariants({ variant: "outline", size: "lg" }),
        "w-full border-2 border-on-surface bg-on-surface py-10 text-xl font-bold tracking-widest text-background hover:bg-secondary hover:text-on-secondary"
      )}
    >
      {header.cta.label}
    </a>

    <div
      class="grid grid-cols-1 gap-8 border-t border-white/10 pt-10 sm:grid-cols-2"
    >
      <div>
        <p class="label-caps-style mb-3 text-muted-foreground">Email</p>
        <a
          href={`mailto:${personal.email}`}
          class="h3-style font-medium text-foreground transition-colors hover:text-primary"
        >
          {personal.email}
        </a>
      </div>
      <div>
        <p class="label-caps-style mb-3 text-muted-foreground">Connect</p>
        <a
          href={`tel:${personal.phone}`}
          class="h3-style font-medium text-foreground transition-colors hover:text-primary"
        >
          {personal.phone}
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap, SplitText } from "@/lib/gsap"
  import { ScrollTrigger } from "gsap/ScrollTrigger"

  const scrollY = ScrollTrigger.getScrollFunc(window) as (() => number) &
    ((pos: number) => void)

  const nav = document.getElementById("main-nav")
  const navContainer = document.getElementById("nav-container")
  const navGlass = document.getElementById("nav-glass")
  const mobileToggle = document.getElementById("mobile-toggle")
  const mobileMenu = document.getElementById("mobile-menu")
  const line1 = mobileToggle?.querySelector(".line-1")
  const line2 = mobileToggle?.querySelector(".line-2")
  const line3 = mobileToggle?.querySelector(".line-3")
  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]")
  )

  let lastScrollY = scrollY()
  const scrollThreshold = 50
  let isNavHidden = false

  // GSAP Timeline for Mobile Menu (Skill: gsap-timeline)
  const menuTl = gsap.timeline({ paused: true, reversed: true })

  if (mobileMenu && line1 && line2 && line3 && nav) {
    menuTl
      .to(mobileMenu, { y: 0, duration: 0.6, ease: "power4.out" })
      .to(line1, { y: 8, rotation: 45, duration: 0.3 }, 0)
      .to(line2, { scaleX: 0, opacity: 0, duration: 0.3 }, 0)
      .to(line3, { y: -8, rotation: -45, duration: 0.3 }, 0)
      // Ensure header stays visible when menu is open
      .to(nav, { yPercent: 0, duration: 0.4, ease: "power2.out" }, 0)
  }

  // Mobile Menu Toggle Logic
  mobileToggle?.addEventListener("click", () => {
    if (menuTl.reversed()) {
      menuTl.play()
      document.body.style.overflow = "hidden"
    } else {
      menuTl.reverse()
      document.body.style.overflow = ""
    }
  })

  const setupNavLinkHover = (link: HTMLAnchorElement) => {
    const textWrapper = link.querySelector<HTMLElement>("[data-nav-link-text]")
    const rawLabel = link.dataset.linkLabel
    if (!textWrapper || !rawLabel) return

    const isActive = link.dataset.active === "true"
    const displayText = isActive ? `[${rawLabel}]` : rawLabel

    textWrapper.textContent = displayText

    // Split into individual characters using SplitText
    // (Skill: gsap-plugins → SplitText)
    const split = SplitText.create(textWrapper, {
      type: "chars",
      charsClass: "nav-char",
    })
    const chars = split.chars as HTMLElement[]

    chars.forEach((c) => {
      c.style.display = "inline-block"
      c.style.willChange = "transform"
    })

    let hoverTl: gsap.core.Timeline | null = null

    link.addEventListener("mouseenter", () => {
      hoverTl?.kill()
      hoverTl = gsap.timeline()

      // Stagger left → right: each character smoothly slants into italic
      // skewX animates the slant visually over time; fontStyle loads proper
      // italic glyphs at the start so they're ready when the skew peaks
      // (Skill: gsap-timeline → position parameter for staggering)
      chars.forEach((char, i) => {
        hoverTl!.to(
          char,
          {
            skewX: -11,
            duration: 0.38,
            ease: "power3.out",
            onStart() {
              char.style.fontStyle = "italic"
            },
          },
          i * 0.06
        )
      })
    })

    link.addEventListener("mouseleave", () => {
      hoverTl?.kill()
      hoverTl = gsap.timeline()

      // Reverse right → left for echo-back feel
      chars.forEach((char, i) => {
        const delay = (chars.length - 1 - i) * 0.045
        hoverTl!.to(
          char,
          {
            skewX: 0,
            duration: 0.3,
            ease: "power2.inOut",
            onStart() {
              char.style.fontStyle = "normal"
            },
          },
          delay
        )
      })
    })
  }

  navLinks.forEach(setupNavLinkHover)

  // Magnetic effect for CTA button
  const magneticCta = document.getElementById("magnetic-cta-btn")
  if (magneticCta) {
    const STRENGTH = 0.8
    const DISTANCE = 150

    const setCursorState = (state: string) => {
      window.dispatchEvent(
        new CustomEvent("cursor-state-change", { detail: { state } })
      )
    }

    const handleMouseMove = (e: MouseEvent) => {
      const rect = magneticCta.getBoundingClientRect()
      const centerX = rect.left + rect.width / 2
      const centerY = rect.top + rect.height / 2

      const deltaX = e.clientX - centerX
      const deltaY = e.clientY - centerY
      const dist = Math.sqrt(deltaX * deltaX + deltaY * deltaY)

      if (dist < DISTANCE) {
        const factor = (1 - dist / DISTANCE) * STRENGTH
        const moveX = deltaX * factor
        const moveY = deltaY * factor

        magneticCta.style.transform = `translate(${moveX}px, ${moveY}px)`
      } else {
        magneticCta.style.transform = "translate(0px, 0px)"
      }
    }

    const handleMouseEnter = () => {
      setCursorState("hidden")
    }

    const handleMouseLeave = () => {
      magneticCta.style.transform = "translate(0px, 0px)"
      setCursorState("default")
    }

    magneticCta.addEventListener("mouseenter", handleMouseEnter)
    document.addEventListener("mousemove", handleMouseMove)
    magneticCta.addEventListener("mouseleave", handleMouseLeave)
  }

  window.addEventListener(
    "scroll",
    () => {
      // Don't hide/show while menu is open
      if (!menuTl.reversed()) return

      const currentScrollY = scrollY()

      // Add/remove glass effect based on scroll position
      if (nav) {
        if ((currentScrollY ?? 0) > scrollThreshold) {
          navGlass?.classList.add(
            "bg-background/80",
            "backdrop-blur-lg",
            "border-b-border"
          )
          nav.classList.remove("mix-blend-difference", "border-transparent")
          navContainer?.classList.remove("py-8")
          navContainer?.classList.add("py-4")
        } else {
          navGlass?.classList.remove(
            "bg-background/80",
            "backdrop-blur-lg",
            "border-b-border"
          )
          nav.classList.add("mix-blend-difference", "border-transparent")
          navContainer?.classList.remove("py-4")
          navContainer?.classList.add("py-8")
        }
      }

      // 2. Visibility State (Headroom Logic: Skill: gsap-performance)
      if ((currentScrollY ?? 0) > 200) {
        if (currentScrollY > lastScrollY && !isNavHidden) {
          // Scrolling Down - Hide using GSAP for smooth transition
          isNavHidden = true
          if (nav)
            gsap.to(nav, {
              yPercent: -100,
              duration: 0.4,
              ease: "power2.inOut",
            })
        } else if (currentScrollY < lastScrollY && isNavHidden) {
          // Scrolling Up - Show
          isNavHidden = false
          if (nav)
            gsap.to(nav, {
              yPercent: 0,
              duration: 0.4,
              ease: "power2.out",
            })
        }
      } else if (isNavHidden) {
        isNavHidden = false
        if (nav)
          gsap.to(nav, {
            yPercent: 0,
            duration: 0.4,
            ease: "power2.out",
          })
      }

      lastScrollY = currentScrollY
    },
    { passive: true }
  )

  // Initial nav state on load (padding + blend mode)
  if (nav) {
    if (scrollY() > scrollThreshold) {
      navGlass?.classList.add(
        "bg-background/80",
        "backdrop-blur-lg",
        "border-b-border"
      )
      nav.classList.remove("mix-blend-difference", "border-transparent")
      navContainer?.classList.remove("py-8")
      navContainer?.classList.add("py-4")
    } else {
      navGlass?.classList.remove(
        "bg-background/80",
        "backdrop-blur-lg",
        "border-b-border"
      )
      nav.classList.add("mix-blend-difference", "border-transparent")
      navContainer?.classList.remove("py-4")
      navContainer?.classList.add("py-8")
    }
  }
</script>

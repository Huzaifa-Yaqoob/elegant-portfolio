---
import { getEntry } from "astro:content"
import { buttonVariants } from "@/lib/button-variants"
import { cn } from "@/lib/utils"

const navEntry = await getEntry("nav", "nav")
if (!navEntry) throw new Error("Navigation configuration not found")

const siteEntry = await getEntry("site", "site")
if (!siteEntry) throw new Error("Site configuration not found")
const { personal } = siteEntry.data

const { header } = navEntry.data
---

<header
  id="main-nav"
  class="fixed top-0 left-0 z-50 w-full border-b border-transparent transition-all duration-300 ease-in-out"
>
  <div
    id="nav-container"
    class="mx-auto flex items-center justify-between px-6 py-8 transition-all duration-300 lg:px-16"
  >
    <!-- Logo -->
    <a
      href={header.logo.href}
      class="group font-heading text-2xl leading-none font-extrabold tracking-tighter uppercase"
    >
      <span class="transition-colors group-hover:text-primary">
        {
          header.logo.label
            .split(".")
            .map((part: string, i: number, arr: string[]) => (
              <>
                {part}
                {i < arr.length - 1 && <span class="text-primary">.</span>}
              </>
            ))
        }
      </span>
    </a>

    <!-- Main Links - Desktop Only for now -->
    <nav class="hidden items-center gap-10 lg:flex">
      {
        header.links.map((link: { label: string; href: string }) => (
          <a
            href={link.href}
            class={cn(
              buttonVariants({ variant: "ghost", size: "sm" }),
              "font-heading tracking-[0.12em] text-[13px]"
            )}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Mobile Toggle -->
    <button
      id="mobile-toggle"
      class="relative z-50 flex h-10 w-10 flex-col items-center justify-center gap-1.5 lg:hidden"
      aria-label="Toggle Menu"
    >
      <span class="line-1 h-0.5 w-6 bg-foreground transition-all duration-300"></span>
      <span class="line-2 h-0.5 w-6 bg-foreground transition-all duration-300"></span>
      <span class="line-3 h-0.5 w-6 bg-foreground transition-all duration-300"></span>
    </button>

    <!-- CTA Button -->
    <div class="hidden lg:block">
      <a 
        href={header.cta.href} 
        class={buttonVariants({ variant: "default" })}
      >
        {header.cta.label}
      </a>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 flex translate-y-full flex-col overflow-y-auto bg-background pt-24 lg:hidden"
>
  <nav class="flex flex-col gap-6 px-8 py-12">
    {
      header.links.map((link: { label: string; href: string }) => (
        <a
          href={link.href}
          class="font-heading text-5xl font-extrabold tracking-tighter uppercase transition-colors hover:text-primary"
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <div class="mt-auto flex flex-col gap-10 px-8 pb-12">
    <a 
      href={header.cta.href} 
      class={cn(buttonVariants({ variant: "default", size: "lg" }), "w-full py-10 text-xl font-bold tracking-widest")}
    >
      {header.cta.label}
    </a>

    <div class="grid grid-cols-1 gap-8 border-t border-white/10 pt-10 sm:grid-cols-2">
      <div>
        <p class="font-heading text-[11px] font-semibold tracking-[0.2em] text-muted-foreground uppercase mb-3">
          Email
        </p>
        <a href={`mailto:${personal.email}`} class="text-2xl font-medium hover:text-primary transition-colors">
          {personal.email}
        </a>
      </div>
      <div>
        <p class="font-heading text-[11px] font-semibold tracking-[0.2em] text-muted-foreground uppercase mb-3">
          Connect
        </p>
        <a href={`tel:${personal.phone}`} class="text-2xl font-medium hover:text-primary transition-colors">
          {personal.phone}
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "@/lib/gsap"

  const nav = document.getElementById("main-nav")
  const navContainer = document.getElementById("nav-container")
  const mobileToggle = document.getElementById("mobile-toggle")
  const mobileMenu = document.getElementById("mobile-menu")
  const line1 = mobileToggle?.querySelector(".line-1")
  const line2 = mobileToggle?.querySelector(".line-2")
  const line3 = mobileToggle?.querySelector(".line-3")

  let lastScrollY = window.scrollY
  const scrollThreshold = 50
  let isNavHidden = false

  // GSAP Timeline for Mobile Menu (Skill: gsap-timeline)
  const menuTl = gsap.timeline({ paused: true, reversed: true })

  if (mobileMenu && line1 && line2 && line3 && nav) {
    menuTl
      .to(mobileMenu, { y: 0, duration: 0.6, ease: "power4.out" })
      .to(line1, { y: 8, rotation: 45, duration: 0.3 }, 0)
      .to(line2, { scaleX: 0, opacity: 0, duration: 0.3 }, 0)
      .to(line3, { y: -8, rotation: -45, duration: 0.3 }, 0)
      // Ensure header stays visible when menu is open
      .to(nav, { yPercent: 0, duration: 0.4, ease: "power2.out" }, 0)
  }

  // Mobile Menu Toggle Logic
  mobileToggle?.addEventListener("click", () => {
    if (menuTl.reversed()) {
      menuTl.play()
      document.body.style.overflow = "hidden"
    } else {
      menuTl.reverse()
      document.body.style.overflow = ""
    }
  })

  window.addEventListener(
    "scroll",
    () => {
      // Don't hide/show while menu is open
      if (!menuTl.reversed()) return

      const currentScrollY = window.scrollY

      // 1. Background State (Glassy Effect) & Dynamic Padding
      if (currentScrollY > scrollThreshold) {
        nav?.classList.add(
          "bg-background/70",
          "backdrop-blur-xl",
          "border-white/5"
        )
        navContainer?.classList.remove("py-8")
        navContainer?.classList.add("py-4")
      } else {
        nav?.classList.remove(
          "bg-background/70",
          "backdrop-blur-xl",
          "border-white/5"
        )
        navContainer?.classList.remove("py-4")
        navContainer?.classList.add("py-8")
      }

      // 2. Visibility State (Headroom Logic: Skill: gsap-performance)
      if (currentScrollY > 200) {
        if (currentScrollY > lastScrollY && !isNavHidden) {
          // Scrolling Down - Hide using GSAP for smooth transition
          isNavHidden = true
          if (nav) gsap.to(nav, {
            yPercent: -100,
            duration: 0.4,
            ease: "power2.inOut",
          })
        } else if (currentScrollY < lastScrollY && isNavHidden) {
          // Scrolling Up - Show
          isNavHidden = false
          if (nav) gsap.to(nav, {
            yPercent: 0,
            duration: 0.4,
            ease: "power2.out",
          })
        }
      } else if (isNavHidden) {
        isNavHidden = false
        if (nav) gsap.to(nav, {
          yPercent: 0,
          duration: 0.4,
          ease: "power2.out",
        })
      }

      lastScrollY = currentScrollY
    },
    { passive: true }
  )
</script>

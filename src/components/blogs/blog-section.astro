---
import { getEntry, getCollection } from "astro:content"
import SectionLayout from "@/layouts/section-layout.astro"
import BlogCard from "@/components/blogs/blog-card.astro"
import { buttonVariants } from "@/lib/button-variants"
import { cn } from "@/lib/utils"
import LucideIcon from "@/components/icons/LucideIcon"

const sectionEntry = await getEntry("section", "blogs")
if (!sectionEntry) return ""

const { title, description, divider_text, badge } = sectionEntry.data
const maxBlogs =
  typeof sectionEntry.data?.max_blogs === "number"
    ? sectionEntry.data.max_blogs
    : 3

const entries = await getCollection("blog")
const blogs = entries
  .filter((b) => !b.data.draft)
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  )
  .slice(0, maxBlogs)
---

<SectionLayout
  title={title}
  description={description}
  badge={badge}
  divider_text={divider_text}
  animateId="blogs"
>
  <div
    id="blog-home-grid"
    class="mt-16 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3"
  >
    {
      blogs.map((blog, i) => (
        <a href={`/blogs/${blog.data.slug}`} class="block">
          <BlogCard blog={blog.data} index={i} />
        </a>
      ))
    }
  </div>

  <div class="mt-12 flex justify-center">
    <a
      href="/blogs"
      id="magnetic-blog-cta"
      class={cn(
        buttonVariants({ variant: "outline", size: "lg" }),
        "border-2 border-on-surface px-12 py-8 font-heading text-sm text-on-surface uppercase"
      )}
    >
      View All Articles
      <LucideIcon
        name="ArrowRight"
        size={18}
        class="transition-transform group-hover/button:translate-x-0.5"
      />
    </a>
  </div>
</SectionLayout>

<script>
  import { gsap } from "@/lib/gsap"

  const animate = () => {
    const cards = document.querySelectorAll("#blog-home-grid .blog-card")

    const tl = gsap.timeline({
      defaults: { ease: "power3.out" },
      scrollTrigger: {
        trigger: "#blog-home-grid",
        start: "top 85%",
        toggleActions: "play none none reverse",
      },
    })

    tl.fromTo(
      cards,
      { y: 80, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.15,
      }
    )
  }

  if ((window as any).__loadingComplete) {
    animate()
  } else {
    window.addEventListener("loading:exiting", animate, { once: true })
  }
</script>

<script>
  window.addEventListener("load", () => {
    const magneticBtn = document.getElementById("magnetic-blog-cta")
    if (magneticBtn) {
      const STRENGTH = 0.8
      const DISTANCE = 150

      const setCursorState = (state: string) => {
        window.dispatchEvent(
          new CustomEvent("cursor-state-change", { detail: { state } })
        )
      }

      const handleMouseMove = (e: MouseEvent) => {
        const rect = magneticBtn.getBoundingClientRect()
        const centerX = rect.left + rect.width / 2
        const centerY = rect.top + rect.height / 2

        const deltaX = e.clientX - centerX
        const deltaY = e.clientY - centerY
        const dist = Math.sqrt(deltaX * deltaX + deltaY * deltaY)

        if (dist < DISTANCE) {
          const factor = (1 - dist / DISTANCE) * STRENGTH
          const moveX = deltaX * factor
          const moveY = deltaY * factor

          magneticBtn.style.transform = `translate(${moveX}px, ${moveY}px)`
        } else {
          magneticBtn.style.transform = "translate(0px, 0px)"
        }
      }

      const handleMouseEnter = () => {
        setCursorState("hidden")
      }

      const handleMouseLeave = () => {
        magneticBtn.style.transform = "translate(0px, 0px)"
        setCursorState("default")
      }

      magneticBtn.addEventListener("mouseenter", handleMouseEnter)
      document.addEventListener("mousemove", handleMouseMove)
      magneticBtn.addEventListener("mouseleave", handleMouseLeave)
    }
  })
</script>

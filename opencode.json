{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    }
  },
  "lsp": true,
  "formatter": true,
  "permission": {
    "*": "ask",
    "todowrite": "allow",
    "bash": {
      "*": "ask",
      "git *": "ask",
      "npm *": "allow",
      "rm *": "deny",
      "grep *": "allow",
      "bun *": "allow",
      "bunx *": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "question": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "doom_loop": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  }
}
